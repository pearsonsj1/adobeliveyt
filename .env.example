# Copy to .env.local and fill in values from your Supabase project.
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only (never NEXT_PUBLIC_*): required for /admin analytics reads — RLS on analytics tables
# only allows SELECT to `authenticated`, while the dashboard runs as the anon key in the browser bundle’s absence.
# Supabase → Settings → API → service_role (keep secret; use only in server / CI).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: YouTube channel ID for @AdobeLiveCommunity (default is set in lib/youtube.ts)
# ADOBE_LIVE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube Data API key — never commit the real value.
# - Supabase.com: Project Settings → Edge Functions → Secrets → YOUTUBE_API_KEY
# - Bolt only: Database icon → Secrets → create YOUTUBE_API_KEY (see README "Bolt" section)
