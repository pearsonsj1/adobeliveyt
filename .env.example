# Copy to .env.local and fill in values from your Supabase project.
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: YouTube channel ID for @AdobeLiveCommunity (default is set in lib/youtube.ts)
# ADOBE_LIVE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxxxx
